#include "WiFiS3.h"

char ssid[] = "BuggyNetworkW10";    // network SSID
char pass[] = "123456789";  // network password

WiFiServer server(5200);
WiFiClient client;
int status = WL_IDLE_STATUS;

bool isConect = false;

const int LED = 13;

// Pin definitions (your mapping)
const int enA = 9;
const int in1 = 8;
const int in2 = 7;

const int enB = 3;
const int in3 = 5;
const int in4 = 4;

const int trigPin = 1;
const int echoPin = 6;

// CD4021 (for CD4040 output)
const int ClockPin = 12;   // 4021 clock
const int LatchPin = 11;   // 4021 latch
const int DataPin  = 10;   // 4021 Q7/Q8 → Arduino

// Interrupt wheel encoder (second wheel)
const int encoderBPin = 2; // interrupt-capable

const int wheelCircumference = 20.4;
const float ticksPerRev = 8.0;
const float cmPerTick = wheelCircumference / ticksPerRev;

const float trackWidth = 14.0;
const float turn90Ticks = (PI * trackWidth / 4.0) / cmPerTick;

long duration;
float distance;
bool stopped = false;
const float baseSpeed = 170;
int SpeedL = baseSpeed * 1.2;
int SpeedR = baseSpeed;

void setup();
void action(int i);
void stop();
void driveStraight();
void driveStraight(int k); 
void turnR();
void turnL();
void turnR(int k);
void turnL(int k);

void loop() {
  char msg;
  int k;
  client = server.available();

  //digitalWrite(latchPin,1);
  //digitalWrite(latchPin,0);
  
  if (client.connected()) {
    if (!isConect){
      client.write("Hello Client\n");
      isConect = true;
    }
    //msg = client.readString();
    if (client && client.available()) {
      msg = client.readStringUntil('\n');
      msg.trim();
    }
    Serial.println(msg);
    if (msg == "S"){
    stopped = true;
    Serial.println("I'm stopping");
    }
    if (msg == "G"){
    stopped = false;
    Serial.println("I'm going");
    }
  }
  
  if (!client.connected()){
    isConect = false;
  }

  // int leftVal = digitalRead(leftIR);  // LOW on white line, HIGH on black
  // int rightVal = digitalRead(rightIR);

  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);
  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH);
  distance = (duration*.0343)/2;

  //Serial.print("Distance (cm): ");
  //Serial.println(distance);
  
  if (distance < 20 || stopped == true) {
    stop();
    return;
  }else if (msg == "A") {
    if (k != 0){
      driveStraight(k);
      stop();
    }else {
      driveStraight();
    } 
  }else if (msg == "B") {
    stop();
  }else if (msg == "C") {
    if (k != 0) {
      turnR(k);
      stop();
    }else {
      turnR();
      stop();
    }
  }else if (msg == "D") {
    if (k != 0) {
      turnL(k);
      stop();
    }else {
      turnL();
      stop();
    }
  }
}

void setup(){
  pinMode (LED, OUTPUT);
  Serial.begin(9600);

  Serial.print("Network named: ");  // Starting an access point
  Serial.println(ssid);
  status = WiFi.beginAP(ssid, pass);
  Serial.println("Network started");

  IPAddress ip = WiFi.localIP();
  Serial.print("IP Address: ");
  Serial.println(ip);
  server.begin();  // Starting a server

  pinMode(enA, OUTPUT);
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  pinMode(enB, OUTPUT);
  pinMode(in3, OUTPUT);
  pinMode(in4, OUTPUT);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  // pinMode(latchPin, OUTPUT);
  // pinMode(clockPin, OUTPUT);
  // pinMode(dataPin, INPUT);

  pinMode(encoderBPin, INPUT);
}

void driveStraight() {
  SpeedR = baseSpeed;
  SpeedL = baseSpeed * 1.2;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void driveStraight(int k) {
  SpeedR = baseSpeed;
  SpeedL = baseSpeed * 1.2;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);  
  digitalWrite(in4, LOW);
  delay (k);
}

void stop() {
  SpeedL = 0;
  SpeedR = 0;
  digitalWrite(enA, LOW);
  digitalWrite(enB, LOW);

  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, LOW);
}

void turnR(){
  SpeedL = 20;
  SpeedR = -20;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);  
  digitalWrite(in2, LOW);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
  delay(10);
}
void turnL(){
  SpeedL = -20;
  SpeedR = 20;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);  
  digitalWrite(in2, LOW);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
  delay(10);
}

void turnR(int k){
  SpeedL += 20;
  SpeedR -= 20;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);  
  digitalWrite(in2, LOW);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
  delay(k);
}
void turnL(int k){
  SpeedL -= 20;
  SpeedR += 20;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);  
  digitalWrite(in2, LOW);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
  delay(k);
}
