#include "WiFiS3.h"

char ssid[] = "BuggyNetworkW10";    // network SSID
char pass[] = "123456789";  // network password

WiFiServer server(5200);
WiFiClient client;
int status = WL_IDLE_STATUS;

bool isConect = false;

const int LED = 13;

// Pin definitions (your mapping)
const int enA = 9;
const int in1 = 8;
const int in2 = 7;

const int enB = 3;
const int in3 = 5;
const int in4 = 4;

// const int trigPin = 1;
// const int echoPin = 6;

// CD4021 (for CD4040 output)
const int ClockPin = 12;   // 4021 clock
const int LatchPin = 11;   // 4021 latch
const int DataPin  = 10;   // 4021 Q7/Q8 → Arduino

// Interrupt wheel encoder (second wheel)
const int encoderBPin = 2; // interrupt-capable

const float wheelCircumference = 20.4;
const float ticksPerRev = 8.0;
const float cmPerTick = wheelCircumference / ticksPerRev;

const float trackWidth = 14.0;
const float turn90Ticks = (PI * trackWidth / 4.0) / cmPerTick;

bool stopped = false;
const float baseSpeed = 180;// this to contral the basespeed of buggy.
const float d = 1.2; // this to contral the differential correction 
float SpeedL = baseSpeed * d;
float SpeedR = baseSpeed;

char msg = '\0';
int k = -1;
String cmd = "";

/*contral table:
A --> drive straght
B --> stop moving
C --> turn right
D --> turn left
S --> stop contral (dont do the command)
G --> start contral (start to do the command)
*/

unsigned long time = 0;
unsigned long start_time = 0;

void setup();
void stop();
void driveStraight();
void turnR();
void turnL();

void loop() {

  WiFiClient newClient = server.available();
  if (newClient) {
    client = newClient;
  }
  
  if (client.connected()) {
    if (!isConect){
      client.write("Hello Client\n");
      isConect = true;
    }
    //msg = client.readString();
    if (client && client.available()) {
      cmd = client.readStringUntil('\n');//cmd should reseave a char with number -> A100, if the action whant to be stop or go, use 0 to be the number
      cmd.trim();
      if (cmd.length() > 0) {
        msg = cmd.charAt(0);//Get the first "char"
      }
      k = 0;
      if (cmd.length() > 1) {//Get the rest as "int"
        k = cmd.substring(1).toInt();
        start_time = millis();
      }
    }
    
    time = millis() - start_time;

    if (msg == 'S') {// S to stop all
      k = 0;
    }
    else if (k > 0 && time >= (unsigned long)k) {// to contral how long the action keep, and new command will break and do the new command
      msg = 'B';
      k = 0;
    }
    Serial.println(msg);

    if (msg == 'S'){// 'S' to stop contral
    stopped = true;
    stop();
    Serial.println("I'm stopping");
    }else if (msg == 'G'){// 'G' to start contral
    stopped = false;
    Serial.println("I'm going");
    }else if (msg == 'A' && !stopped){// if A to keep drive straight, 
      driveStraight();
    }else if (msg == 'B' && !stopped){// if B to stop
      stop();
    }else if (msg == 'C' && !stopped){// if C to keep turn right
      turnR();
    }else if (msg == 'D' && !stopped){// if D to keep turn left
      turnL();
    }
  }
  if (!client.connected()){
    isConect = false;
    stopped = true;
    stop();
  }
}

void setup(){
  pinMode (LED, OUTPUT);
  Serial.begin(9600);

  Serial.print("Network named: ");  // Starting an access point
  Serial.println(ssid);
  status = WiFi.beginAP(ssid, pass);
  Serial.println("Network started");

  IPAddress ip = WiFi.localIP();
  Serial.print("IP Address: ");
  Serial.println(ip);
  server.begin();  // Starting a server

  pinMode(enA, OUTPUT);
  pinMode(in1, OUTPUT);
  pinMode(in2, OUTPUT);
  pinMode(enB, OUTPUT);
  pinMode(in3, OUTPUT);
  pinMode(in4, OUTPUT);

  pinMode(encoderBPin, INPUT);
}

void driveStraight() {
  SpeedR = baseSpeed;
  SpeedL = baseSpeed * d;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void stop() {
  SpeedL = 0;
  SpeedR = 0;
  digitalWrite(enA, LOW);
  digitalWrite(enB, LOW);

  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, LOW);
}

void turnR(){
  SpeedL = 20;
  SpeedR = 20;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);  
  digitalWrite(in2, LOW);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}
void turnL(){
  SpeedL = 20;
  SpeedR = 20;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, LOW);  
  digitalWrite(in2, HIGH);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}
