void driveStraight() {
  SpeedR = baseSpeed;
  SpeedL = baseSpeed * d;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);
  digitalWrite(in2, LOW);
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

void stopBuggy() {
  SpeedL = 0;
  SpeedR = 0;
  digitalWrite(enA, LOW);
  digitalWrite(enB, LOW);

  digitalWrite(in1, LOW);
  digitalWrite(in2, LOW);
  digitalWrite(in3, LOW);
  digitalWrite(in4, LOW);
}

void turnR(){
  SpeedL = R;
  SpeedR = R;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, HIGH);  
  digitalWrite(in2, LOW);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, LOW);
  digitalWrite(in4, HIGH);
}
void turnL(){
  SpeedL = R;
  SpeedR = R;
  analogWrite(enA, SpeedL);  
  digitalWrite(in1, LOW); 
  digitalWrite(in2, HIGH);  // Left reverse/slow
  analogWrite(enB, SpeedR);
  digitalWrite(in3, HIGH);
  digitalWrite(in4, LOW);
}

byte myShiftIn(int myDataPin, int myClockPin){
  int i;
  int temp = 0;
  int pinState;
  byte myDataIn = 0;

  for (i = 7; i >= 0; i--){
    digitalWrite(myClockPin, 0);
    delayMicroseconds(1);
    temp = digitalRead(myDataPin);
    if (temp){
      pinState = 1;

      myDataIn = myDataIn | (1 << i);
    }else {
      pinState = 0;
    }

    digitalWrite(myClockPin, 1);
  }
  return myDataIn;
}

byte read4021 (int latchPin, int dataPin, int clockPin){
  digitalWrite(latchPin, 1);
  delayMicroseconds(20);
  digitalWrite(latchPin, 0);

  return myShiftIn(dataPin, clockPin);

}
